# --- Production environment for the API (Railway / any PHP host) ---
# Copy these into your host's environment variables (do NOT commit real secrets).

APP_NAME="Ndaw-Resto"
APP_ENV=production
APP_KEY=            # run: php artisan key:generate --show   (then paste here)
APP_DEBUG=false
APP_URL=https://YOUR-API-DOMAIN            # e.g. https://ndaw-resto-api.up.railway.app
APP_FRONTEND_URL=https://YOUR-WEB-DOMAIN   # e.g. https://ndaw-resto.vercel.app

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=error

# Database — paste your Supabase connection details (Settings → Database).
# Use the "Session/Transaction pooler" host for serverless (port 6543 or 5432).
DB_CONNECTION=pgsql
DB_HOST=            # e.g. aws-0-eu-west-2.pooler.supabase.com
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=        # e.g. postgres.<project-ref>
DB_PASSWORD=        # your Supabase database password
DB_SSLMODE=require
# When sharing an existing Supabase project, isolate the app in its own schema:
DB_SCHEMA=ndaw_resto

# No Redis needed in production: use the database drivers.
CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database

# --- Serverless (Vercel) specifics ---
# Only /tmp is writable on Vercel, and logs must go to stderr.
VIEW_COMPILED_PATH=/tmp
LOG_CHANNEL=stderr

# Sanctum / CORS — allow the deployed frontend.
SANCTUM_STATEFUL_DOMAINS=YOUR-WEB-DOMAIN
FRONTEND_URL=https://YOUR-WEB-DOMAIN

# Filesystem: on serverless/container hosts local disk is ephemeral — use
# Cloudinary for persistent uploads (else uploads won't survive restarts).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

MAIL_MAILER=log
