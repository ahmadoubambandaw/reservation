# --- Production environment for the web app (Vercel) ---
# Set these as Environment Variables in the Vercel project settings.

# The deployed API base URL (from Railway), including /api/v1.
NEXT_PUBLIC_API_URL=https://YOUR-API-DOMAIN/api/v1

# The platform's bare host (used by proxy.ts to detect restaurant custom
# domains / subdomains). e.g. ndaw-resto.vercel.app  (or your own domain)
NEXT_PUBLIC_APP_HOST=YOUR-WEB-DOMAIN
